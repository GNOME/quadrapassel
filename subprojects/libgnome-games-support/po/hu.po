#. Empty State
#: games/scores/dialog.vala:83
msgid "No scores yet"
msgstr "Még nincsenek pontszámok"

#: games/scores/dialog.vala:88
msgid "Play some games and your scores will show up here."
msgstr "Játsszon pár játékot, és a pontszámai itt fognak megjelenni."

#: games/scores/dialog.vala:97
msgid "Clear Scores…"
msgstr "Pontszámok törlése…"

#. Translators: %1$s is the category type, %2$s is the category (e.g. "New Score for Level: 1")
#: games/scores/dialog.vala:118
#, c-format
msgid "New Score for %1$s: %2$s"
msgstr "Új %1$s pontszám: %2$s"

#: games/scores/dialog.vala:119
msgid "Score"
msgstr "Pontszám"

#. Translators: %1$s is the category type, %2$s is the category (e.g. "New Time for Level: 1")
#: games/scores/dialog.vala:124
#, c-format
msgid "New Time for %1$s: %2$s"
msgstr "Új %1$s idő: %2$s"

#: games/scores/dialog.vala:125
msgid "Time"
msgstr "Idő"

#: games/scores/dialog.vala:134
msgid "Congratulations!"
msgstr "Gratulálunk!"

#. Translators: %1$s is the category type, %2$s is the category (e.g. "Level: 1")
#: games/scores/dialog.vala:141 games/scores/dialog.vala:209
#, c-format
msgid "%1$s: %2$s"
msgstr "%1$s: %2$s"

#: games/scores/dialog.vala:387
msgid "Player"
msgstr "Játékos"

#: games/scores/dialog.vala:393
msgid "_New Game"
msgstr "Ú_j játék"

#: games/scores/dialog.vala:404
msgid "_Quit"
msgstr "_Kilépés"

#: games/scores/dialog.vala:436
msgid "Clear All Scores?"
msgstr "Törli az összes pontszámot?"

#: games/scores/dialog.vala:437
msgid "This will clear every score for every layout."
msgstr "Ez törli az összes pontszámot minden elrendezésnél."

#: games/scores/dialog.vala:440
msgid "_Cancel"
msgstr "_Mégse"

#: games/scores/dialog.vala:441
msgid "Clear All"
msgstr "Összes törlése"
